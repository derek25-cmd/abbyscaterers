{
  "name": "my-electron-app",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "start": "electron .",
    "test": "echo \"Error: no test specified\" && exit 1",
    "package": "electron-packager . --overwrite --asar=true --platform=darwin --arch=x64 --prune=true --out=release-builds",
    "dist": "electron-builder"
  },
  "build": {
    "appId": "your.app.id",
    "productName": "MyElectronApp",
    "directories": {
      "output": "dist",
      "app": "."
    },
    "files": [
      "package.json",
      "index.js",
      "preload.js",
      {
        "from": "../out",
        "to": "out",
        "filter": [
          "**/*"
        ]
      }
    ],
    "mac": {},
    "win": {},
    "linux": {}
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "glib": "^1.3.0"
  },
  "devDependencies": {
    "electron": "^36.3.2",
    "electron-builder": "^24.13.3",
    "electron-devtools-installer": "^3.2.0",
    "packager": "^0.1.9"
  }
}
