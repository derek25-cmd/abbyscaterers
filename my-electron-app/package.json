{
  "name": "my-electron-app",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
  "start": "electron .",
  "test": "echo \"Error: no test specified\" && exit 1",
  "package": "electron-packager . --overwrite --asar=true --platform=darwin --arch=x64 --icon=assets/icons/mac/icon.icns --prune=true --out=release-builds",
  "dist": "./node_modules/.bin/electron-builder"
},
"build": {
  "appId": "your.app.id",
  "productName": "MyElectronApp",
  "directories": {
    "output": "dist"
  },
  "files": [
    "package.json",
    "index.js",
    "preload.js",
    "../out/**/*"
  ],
  "mac": {
    "icon": "assets/icons/mac/icon.icns"
  },
  "win": {
    "icon": "assets/icons/win/icon.ico"
  },
  "linux": {
    "icon": "assets/icons/png/512x512.png"
  }

},
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "electron-is-dev": "^3.0.1"
  },
  "devDependencies": {
    "electron": "^36.3.2",
    "electron-builder": "^24.13.3",
    "packager": "^0.1.9"
  }
}
