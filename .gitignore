# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# Update .gitignore to exclude all large/unnecessary files
cat > .gitignore << 'EOF'
# Dependencies
node_modules/
.pnp/
.pnp.js

# Build outputs
dist/
build/
out/
.next/
my-electron-app/dist/
my-electron-app/out/
my-electron-app/release/
my-electron-app/node_modules/

# Environment files
.env
.env.local
.env.production.local
.env.development.local

# Debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.log

# Editor directories
.vscode/*
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# OS files
.DS_Store
Thumbs.db

# Large binaries
*.exe
*.dmg
*.AppImage
*.snap
*.deb
*.rpm
*.dmg
linux-unpacked/
win-unpacked/
mac-unpacked/
electron/dist/
EOF

git add .gitignore
git commit -m "Update .gitignore to exclude node_modules and binaries"