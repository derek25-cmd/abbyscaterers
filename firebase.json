{
  "hosting": {
    "source": ".",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "frameworksBackend": {
      "region": "us-central1"
    },
    "build": {
      "steps": [
        {
          "name": "fetch",
          "args": ["."],
          "env": {}
        },
        {
          "name": "npm install"
        },
        {
          "name": "npm run build"
        }
      ]
    }
  },
  "apphosting": [
    {
      "backendId": "catersmart-1",
      "rootDir": ".next/standalone",
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log",
        "functions"
      ]
    },
    {
      "backendId": "catersmart-1",
      "rootDir": "/.next/standalone",
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log",
        "functions"
      ]
    }
  ]
}
